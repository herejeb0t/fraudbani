      <script>
        
        let openedForm = null
let openedBtn = null

function toggleReply(id, btn) {
  const form = document.getElementById('reply-' + id)

  if (openedForm && openedForm !== form) {
    openedForm.style.display = 'none'
    if (openedBtn) openedBtn.textContent = 'Responder'
  }

  if (form.style.display === 'none') {
    form.style.display = 'block'
    btn.textContent = 'Cancelar'
    openedForm = form
    openedBtn = btn
  } else {
    form.style.display = 'none'
    btn.textContent = 'Responder'
    openedForm = null
    openedBtn = null
  }
}
        
        document.querySelectorAll('form[id^="reply-"]').forEach(form => {
  form.addEventListener('submit', (e) => {
    const textarea = form.querySelector('textarea')

    if (!textarea.value || textarea.value.length < 3) {
      e.preventDefault()
      textarea.style.borderBottom = '1px solid #F434AA'
    }
  })
})
        
        let openedReplies = null

function toggleReplies(id, btn) {
  const currentBox = document.getElementById('replies-' + id)

  if (openedReplies && openedReplies !== currentBox) {
    openedReplies.style.display = 'none'

    const prevBtn = document.querySelector(
      `[onclick*="${openedReplies.id.replace('replies-', '')}"]`
    )

    if (prevBtn) {
      const count = openedReplies.children.length
      prevBtn.textContent = `Ver respuestas (${count})`
    }
  }

  if (currentBox.style.display === 'none') {
    currentBox.style.display = 'block'
    btn.textContent = 'Ocultar respuestas'
    openedReplies = currentBox
  } else {
    currentBox.style.display = 'none'
    btn.textContent = `Ver respuestas (${currentBox.children.length})`
    openedReplies = null
  }
}
      </script>