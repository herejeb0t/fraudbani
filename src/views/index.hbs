        <script>
          document.addEventListener('DOMContentLoaded', () => {
          const dialog = (title, dialog, color, img) => {
            const advDiv = document.querySelector('.advDiv')
            
            advDiv.innerHTML = ''
            
            const diag = document.createElement('dialog')
            
            diag.classList.add('adv')
            
            if (title) {
              const h5 = document.createElement('h5')
              h5.classList.add('poppinsLabel')
    h5.innerHTML = title
    diag.appendChild(h5)
  }
  
  if (img) {
    const pic = document.createElement('img')
    pic.src = img
    diag.appendChild(pic)
  }
  
  if (dialog) {
    const adv = document.createElement('p')
    adv.classList.add('poppinsText')
    adv.setAttribute('style', 'font-size: .8rem;')
    adv.innerHTML = dialog
    diag.appendChild(adv)
  }
  
  const btn = document.createElement('button')
  btn.classList.add('basicBtn')
  btn.classList.add('poppinsLabel')
  btn.setAttribute('style', 'font-size: .8rem; margin-top: 20px;')
  btn.innerHTML = 'CERRAR'
  diag.appendChild(btn)
  
  btn.addEventListener('click', () => {
    diag.close()
  })
  
  advDiv.appendChild(diag)
  
  diag.showModal()
}
          
